# Cloudflare API credentials (use API token OR email+global API key)
CLOUDFLARE_EMAIL=your-cloudflare-email@example.com
CLOUDFLARE_API_KEY=your-cloudflare-global-api-key
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Cloudflare account / zone / tunnel identifiers
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_TUNNEL_ID=your-tunnel-id

# Base domain used for subdomains (e.g. example.com -> app.example.com)
BASE_DOMAIN=example.com

# Secret used to sign session cookies (generate a long random string)
SESSION_SECRET=change-this-to-a-long-random-string

# Optional paths (defaults are shown)
# CONFIG_PATH=/app/data/config.json
# CLOUDFLARED_CONFIG=/app/cloudflared-config.yml
# PORT=3457
